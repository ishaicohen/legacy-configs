// Public Server Config
// Based on legacy6.config, tuned for casual public play
//
// Key differences from competitive configs:
// - No ready-up requirement, warmup auto-expires
// - All classes and weapons unrestricted
// - Airstrikes and artillery allowed
// - Team auto-balance enabled, team switching allowed
// - XP/skill progression enabled (resets each map)
// - Voting: shuffle, next map, balance, kick allowed
// - Competitive-only features (team lock, tech pause) disabled via env vars

configname "^3Falafel ^7& ^1Firefights ^7Public"

init
{
	setl sv_pure "1"
	setl sv_cheats "0"
	setl sv_fps "40"
	set sv_floodProtect "1"

	setl g_gameType "2"
	setl g_warmup "15"
	setl g_doWarmup "1"
	setl g_voiceChatsAllowed "100"
	setl g_spectatorInactivity "120"
	setl g_friendlyFire "1"
	// Allow all soldiers to carry heavy weapons (100 = no restriction)
	setl g_heavyWeaponRestriction "100"

	// More forgiving charge times than 6v6 competitive
	setl g_medicChargeTime "30000"
	setl g_fieldopsChargeTime "25000"
	setl g_engineerChargeTime "20000"
	setl g_soldierChargeTime "20000"
	setl g_covertopschargetime "20000"
	setl g_stickyCharge "0"
	setl g_landminetimeout "0"

	// Drop ammo and health on death — more accessible pub experience
	setl g_dropAmmo "1"
	setl g_dropHealth "1"

	// Auto-balance and allow team switching
	setl g_teamForceBalance "1"
	setl g_filtercams "1"
	setl g_fastres "0"
	setl g_noTeamSwitching "0"
	setl g_alliedmaxlives "0"
	setl g_axismaxlives "0"
	setl g_speed "320"
	setl g_gravity "800"
	setl g_knockback "1000"
	setl g_autoFireteams "1"
	setl g_countryFlags "1"
	setl g_misc "0"

	// XP and skill progression enabled (resets per map in stopwatch)
	setl g_skillrating "2"
	setl g_dropObjDelay "3000"

	// All classes open, no per-class or per-weapon limits
	setl team_maxSoldiers "-1"
	setl team_maxMedics "-1"
	setl team_maxEngineers "-1"
	setl team_maxFieldops "-1"
	setl team_maxCovertops "-1"
	setl team_maxplayers "0"
	setl team_nocontrols "0"

	setl team_maxFlamers "1"
	setl team_maxMachineguns "1"
	setl team_maxMortars "1"
	setl team_maxRockets "1"
	setl team_maxRiflegrenades "2"

	// Allow airstrikes and artillery — core pub fun
	setl team_maxAirstrikes "3.0"
	setl team_maxArtillery "3.0"

	setl team_riflegrenades "1"

	// Game auto-starts after warmup expires — no ready-up required
	setl match_latejoin "1"
	setl match_minplayers "1"
	setl match_readypercent "0"
	setl match_timeoutcount "0"
	setl match_timeoutlength "120"
	setl match_warmupDamage "2"

	setl sv_minping "0"
	setl sv_maxping "0"

	setl pmove_fixed "0"
	setl pmove_msec "8"

	// Map rotation — nextmap is set per-map block below

	// Voting — focused on pub quality-of-life
	setl g_allowVote "1"
	setl vote_allow_balancedteams "1"
	setl vote_allow_config "0"
	setl vote_allow_friendlyfire "0"
	setl vote_allow_gametype "0"
	setl vote_allow_kick "1"
	setl vote_allow_map "1"
	setl vote_allow_matchreset "0"
	setl vote_allow_mutespecs "1"
	setl vote_allow_muting "1"
	setl vote_allow_nextmap "1"
	setl vote_allow_referee "1"
	setl vote_allow_shuffleteams "1"
	setl vote_allow_shuffleteams_norestart "1"
	setl vote_allow_surrender "0"
	setl vote_allow_swapteams "0"
	setl vote_allow_timelimit "0"
	setl vote_allow_warmupdamage "0"
	setl vote_allow_maprestart "0"
	setl vote_allow_cointoss "0"
	setl vote_allow_antilag "1"
	setl vote_limit "99"
	setl vote_percent "51"

	setl g_mapscriptdirectory "mapscripts"
	setl g_mapConfigs ""

	// Skills start at 0 and build during the map
	setl skill_battlesense "0"
	setl skill_engineer "0"
	setl skill_medic "0"
	setl skill_fieldops "0"
	setl skill_lightweapons "0"
	setl skill_soldier "0"
	setl skill_covertops "0"

	setl g_intermissiontime "25"
	setl g_multiview "1"
	setl g_shove "50"
	setl g_shoveNoZ "1"
	setl g_antiwarp "1"
	setl g_maxWarp "8"
	setl g_antilag "1"
	setl g_realHead "1"
	setl g_fixedphysics "1"
	setl g_fixedphysicsfps "125"
	setl g_campaignfile ""

	setl g_pronedelay "3"
	setl g_teamInfoUpdateRate "500"
	setl g_legacyRevives "1"

	// combinedfixes.lua — competitive features disabled via docker env vars:
	// CF_DEFAULT_CLASS=false  (don't force everyone to Medic)
	// CF_TEAM_LOCK=false      (don't lock teams on round start)
	// CF_TECH_PAUSE=false     (no competitive tech pause system)
	// CF_GUID_BLOCKER=false   (no LAN-event GUID block)
	setl lua_modules "luascripts/combinedfixes.lua"

	set g_log "public.log"

	command "sv_cvarempty"

	// Basic fairness — prevent mouse exploit cvars
	command "sv_cvar cl_freelook EQ 1"
	command "sv_cvar cl_pitchspeed EQ 0"
	command "sv_cvar cl_yawspeed EQ 0"

	// Wider FoV allowance for casual players
	command "sv_cvar cg_fov IN 60 130"

	// Anti-wallhack rendering enforcements
	command "sv_cvar r_drawentities EQ 1"
	command "sv_cvar r_drawworld EQ 1"
	command "sv_cvar r_showtris EQ 0"
	command "sv_cvar r_lightmap EQ 0"
	command "sv_cvar r_wolffog EQ 0"
}

map default
{
	set g_userTimeLimit "0"
	setl g_useralliedrespawntime "12"
	setl g_useraxisrespawntime "15"
	setl g_moverScale "1.0"
	setl team_maxLandmines "10"
	command "sv_cvar r_ambientScale EQ 1.5"
	// Fallback: if map not listed below, loop back to radar
	set nextmap "map radar"
}

// ── Map rotation (matches MAPS in docker-compose) ──────────────────────────
map radar          { set nextmap "map fueldump" }
map fueldump       { set nextmap "map sw_goldrush_te" }
map sw_goldrush_te { set nextmap "map sw_oasis_b3" }
map sw_oasis_b3    { set nextmap "map et_beach" }
map et_beach       { set nextmap "map etl_supply" }
map etl_supply { set nextmap "map etl_frostbite" }
map etl_frostbite { set nextmap "map etl_adlernest" }
map etl_adlernest  { set nextmap "map braundorf_b4" }
map braundorf_b4   { set nextmap "map etl_ice" }
map etl_ice        { set nextmap "map et_brewdog" }
map et_brewdog        { set nextmap "map bremen_b3" }
map bremen_b3      { set nextmap "map railgun" }
map railgun        { set nextmap "map radar" }
